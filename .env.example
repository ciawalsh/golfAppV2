# ──────────────────────────────────────────────
# Firebase Core
# ──────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy_your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:ios:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────
# Google Sign-In (build-time only, used in app.config.ts)
# ──────────────────────────────────────────────
GOOGLE_SIGNIN_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_SIGNIN_IOS_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ──────────────────────────────────────────────
# Sentry (error reporting)
# ──────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ──────────────────────────────────────────────
# Notes
# ──────────────────────────────────────────────
# 1. Copy this file to .env and fill in real values
# 2. NEVER commit .env — it is in .gitignore
# 3. For EAS builds, set these in eas.json or EAS Secrets
# 4. Firebase config values are in Firebase Console > Project Settings > General > Your apps
# 5. Google Sign-In client IDs are in Google Cloud Console > APIs & Services > Credentials
# 6. EXPO_PUBLIC_* vars are inlined at build time and visible in the JS bundle
# 7. GOOGLE_SIGNIN_* vars (no EXPO_PUBLIC_ prefix) are read by app.config.ts at build time only
