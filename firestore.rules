rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasCurrentUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function matchesPostAuthorProfile() {
      return hasCurrentUserProfile()
        && request.resource.data.userName == currentUserProfile().displayName
        && request.resource.data.userAvatar == currentUserProfile().photoURL
        && request.resource.data.userHandicap == currentUserProfile().handicap;
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['subscription']);
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
    }

    // Subscription state is written only by Cloud Functions (admin SDK)
    // No client write rules needed — admin SDK bypasses rules

    // Content collections served via callable Functions.
    // Deny direct client reads so premium URLs never leak from Firestore.
    match /golfCenterCoaches/{coachId} {
      match /courses/{courseId} {
        allow read: if false;
      }
    }

    match /golfCenterVideos/{docId} {
      allow read: if false;
    }

    match /golfCenterVideoGenres/{docId} {
      allow read: if false;
    }

    match /dormyVideos/{docId} {
      allow read: if false;
    }

    match /dormyVideoGenres/{docId} {
      allow read: if false;
    }

    match /articles/{articleId} {
      allow read: if request.auth != null;
    }

    // Golf data collections — read-only for authenticated users
    match /golfClubs/{clubId} {
      allow read: if request.auth != null;
    }

    match /golfCourses/{courseId} {
      allow read: if request.auth != null;
    }

    match /golfTees/{teeId} {
      allow read: if request.auth != null;
    }

    // User rounds — subcollection under users
    match /users/{userId}/rounds/{roundId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community posts — any auth user can read; owner creates; strict counter updates
    match /communityPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && matchesPostAuthorProfile()
        && request.resource.data.likes == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0
        && request.resource.data.createdAt == request.time;
      allow update: if request.auth != null
        && (
          // Owner can update their own post content (but NOT counters)
          (
            resource.data.userId == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny([
                  'likes',
                  'likedBy',
                  'commentCount',
                  'userId',
                  'userName',
                  'userAvatar',
                  'userHandicap',
                  'createdAt',
                ])
          )
          // Like: user adds themselves to likedBy, increments likes by exactly 1
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy'])
            && !(request.auth.uid in resource.data.likedBy)
            && request.auth.uid in request.resource.data.likedBy
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1
            && request.resource.data.likes == resource.data.likes + 1
          )
          // Unlike: user removes themselves from likedBy, decrements likes by exactly 1
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy'])
            && request.auth.uid in resource.data.likedBy
            && !(request.auth.uid in request.resource.data.likedBy)
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1
            && request.resource.data.likes == resource.data.likes - 1
          )
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if false;
        allow delete: if false;
      }
    }
  }
}
