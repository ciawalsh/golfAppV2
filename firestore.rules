rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
    }

    // Subscription state is written only by Cloud Functions (admin SDK)
    // No client write rules needed — admin SDK bypasses rules

    // Content collections — read-only for authenticated users
    match /golfCenterCoaches/{coachId} {
      allow read: if request.auth != null;
      match /courses/{courseId} {
        allow read: if request.auth != null;
      }
    }

    match /golfCenterVideos/{docId} {
      allow read: if request.auth != null;
    }

    match /golfCenterVideoGenres/{docId} {
      allow read: if request.auth != null;
    }

    match /dormyVideos/{docId} {
      allow read: if request.auth != null;
    }

    match /dormyVideoGenres/{docId} {
      allow read: if request.auth != null;
    }

    match /articles/{articleId} {
      allow read: if request.auth != null;
    }

    // Golf data collections — read-only for authenticated users
    match /golfClubs/{clubId} {
      allow read: if request.auth != null;
    }

    match /golfCourses/{courseId} {
      allow read: if request.auth != null;
    }

    match /golfTees/{teeId} {
      allow read: if request.auth != null;
    }

    // User rounds — subcollection under users
    match /users/{userId}/rounds/{roundId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community posts — any auth user can read; owner creates; likes/comments update allowed
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy', 'commentCount'])
            && request.resource.data.likes >= 0
            && request.resource.data.commentCount >= 0
          )
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
