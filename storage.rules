rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Deny all by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // User avatars — owner can write their own avatar
    // Path: users/{userId}/avatar.jpg
    // ──────────────────────────────────────────────
    match /users/{userId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──────────────────────────────────────────────
    // Community post images — any auth user can upload
    // Path: community/posts/{postId}/{timestamp}.jpg
    // Ownership enforced at Firestore level (post doc rules)
    // ──────────────────────────────────────────────
    match /community/posts/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──────────────────────────────────────────────
    // Video & image content — read-only for auth users
    // Uploaded by admin or Cloud Functions only; no client writes.
    // Paths match actual bucket structure (case-sensitive).
    // ──────────────────────────────────────────────
    match /AlexElliotGolfCenter/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /DormyVideos/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /ProCoaches/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /exploreImages/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /scorecards/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Legacy avatar path from old app — read-only so existing
    // profile photos still resolve for migrated users
    match /userProfilePics/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
