rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Deny all by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // User avatars — owner can write their own avatar
    // Path: users/{userId}/avatar.jpg
    // ──────────────────────────────────────────────
    match /users/{userId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──────────────────────────────────────────────
    // Community post images — any auth user can upload
    // Path: community/posts/{postId}/{timestamp}.jpg
    // Ownership enforced at Firestore level (post doc rules)
    // ──────────────────────────────────────────────
    match /community/posts/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ──────────────────────────────────────────────
    // Protected media content — delivered via signed URLs from Cloud Functions.
    // Direct client reads are denied so auth-only users cannot bypass entitlement
    // checks by fetching Storage objects themselves.
    // ──────────────────────────────────────────────
    match /AlexElliotGolfCenter/{allPaths=**} {
      allow read: if false;
    }

    match /DormyVideos/{allPaths=**} {
      allow read: if false;
    }

    // Public/authenticated coach and article imagery.
    match /ProCoaches/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /exploreImages/{allPaths=**} {
      allow read: if request.auth != null;
    }

    match /scorecards/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Legacy avatar path from old app — read-only so existing
    // profile photos still resolve for migrated users
    match /userProfilePics/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
